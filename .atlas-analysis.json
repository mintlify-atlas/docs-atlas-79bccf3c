  "keyFeatures": [
    "Real-time MLB game tracking with live scores and play-by-play",
    "Weekly and daily schedule views with game status updates",
    "Comprehensive player statistics and comparison tools",
    "Interactive MLB Stats API playground for exploring endpoints",
    "Team standings, transactions, and season information",
    "Favorites system for tracking preferred teams and players",
    "Responsive design with dark mode support"
  ],
  "publicApiSurface": [
    "fetchMLB(endpoint, params) - Core fetch wrapper for MLB Stats API",
    "fetchSeason(year, sportId) - Retrieve season information",
    "fetchWeekSchedule(date, sportId) - Get weekly game schedule",
    "fetchDaySchedule(date, sportId) - Get daily game schedule",
    "fetchfeedLive(gamePk) - Fetch live game feed data",
    "fetchBoxscore(gamePk, params) - Get game boxscore",
    "fetchLinescore(gamePk) - Get game linescore",
    "fetchWinProbability(gamePk) - Get win probability data",
    "fetchWeekTransactions(params) - Get weekly transactions",
    "createPreset(build) - Create reusable fetch preset functions"
  ]
}
